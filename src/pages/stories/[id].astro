---
export function getStaticPaths() {
  const storyModules = import.meta.glob("../../data/stories/*.json", { eager: true });
  return Object.values(storyModules)
    .map((module) => module.default)
    .filter((story) => story.status !== "draft")
    .sort((a, b) => b.date.localeCompare(a.date))
    .map((story, index, stories) => ({
      params: { id: story.id },
      props: {
        story,
        previousStory: stories[index + 1] ?? null,
        nextStory: stories[index - 1] ?? null,
      },
    }));
}

const { story, previousStory, nextStory } = Astro.props;
const assetPath = (path) => `../../${path.replace(/^\//, "")}`;
const stylePath = `${assetPath("styles.css")}?v=20260630-4`;
const storyPath = (targetStory) => `../${targetStory.id}/`;
const defaultStoryImage = "assets/story_shopping_back.png";
const storyImagePath = (story) => assetPath(story.image ?? defaultStoryImage);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{story.title} | 三人ノート</title>
    <meta name="description" content={story.summary} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Klee+One:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={stylePath} />
  </head>
  <body>
    <header class="site-header" aria-label="サイトヘッダー">
      <a class="brand" href="../../#top" aria-label="三人ノート トップへ">
        <span class="brand-mark">三</span>
        <span>三人ノート</span>
      </a>
      <nav class="nav" aria-label="メインナビゲーション">
        <a href="../../#today">今日のこと</a>
        <a href="../../#line">トーク</a>
        <a href="../../#characters">書いてる人</a>
        <a href="../">置き場</a>
        <a href="../../#about">この場所</a>
      </nav>
    </header>

    <main class="reading-page">
      <article class="reading-paper">
        <a class="back-link" href="../">書き足した日たちへ戻る</a>
        <h1>{story.title}</h1>
        <img
          class="reading-image"
          src={storyImagePath(story)}
          alt={story.imageAlt ?? ""}
          style={story.imagePosition ? `object-position: ${story.imagePosition}` : undefined}
        />
        <div class="reading-body">
          {story.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <nav class="story-pager" aria-label="前後の話">
          {previousStory ? (
            <a href={storyPath(previousStory)}>
              <span>前の話</span>
              <strong>{previousStory.title}</strong>
            </a>
          ) : (
            <span></span>
          )}
          <a class="pager-center" href="../">一覧へ戻る</a>
          {nextStory ? (
            <a href={storyPath(nextStory)}>
              <span>次の話</span>
              <strong>{nextStory.title}</strong>
            </a>
          ) : (
            <span></span>
          )}
        </nav>
      </article>
    </main>
  </body>
</html>
