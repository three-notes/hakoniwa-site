---
import { externalLinks } from "../siteConfig";

const dailyModules = import.meta.glob("../data/daily/*.json", { eager: true });
const dailyItems = Object.values(dailyModules)
  .map((module) => module.default)
  .sort((a, b) => a.date.localeCompare(b.date));

const storyModules = import.meta.glob("../data/stories/*.json", { eager: true });
const stories = Object.values(storyModules)
  .map((module) => module.default)
  .filter((story) => story.status !== "draft")
  .sort((a, b) => b.date.localeCompare(a.date));

const assetPath = (path) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;

const latestDaily = dailyItems.at(-1);
const latestLineDaily = [...dailyItems].reverse().find((item) => item.line?.hasLine);
const daysSinceLine = latestDaily && latestLineDaily
  ? Math.max(0, Math.round((Date.parse(latestDaily.date) - Date.parse(latestLineDaily.date)) / 86400000))
  : 0;

const previousLineDateLabel = daysSinceLine === 1 ? "昨日" : `${daysSinceLine}日前`;
const latestLineLabel = daysSinceLine === 0 ? "最終更新 今日" : `最終更新 ${daysSinceLine}日前`;
const latestLineLead = "三人のトークです。";

const todayPost = {
  date: latestDaily.date,
  seed: latestDaily.seed.label,
  title: latestDaily.x.hasPost ? latestDaily.noteMemo.titleCandidate : "今日はまだ何も書いてません。",
  owner: latestDaily.eventOwner,
  handle: latestDaily.x.handle ?? `@${latestDaily.eventOwner}`,
  hasPost: latestDaily.x.hasPost,
  lines: latestDaily.x.text ? latestDaily.x.text.split("\n") : [],
  fallback: latestDaily.x.hasPost
    ? ""
    : "でも昨日のトークはちょっと残してます。駅で見るだけだった朝のことは、週末メモに回すかもしれません。",
};

const lineThread = {
  owner: latestLineDaily.eventOwner,
  ownerLabel: `${latestLineDaily.eventOwner}の日`,
  lastUpdatedLabel: latestLineLabel,
  title: latestLineDaily.line.title ?? "三人のトーク",
  messages: latestLineDaily.line.messages,
  lead: latestLineLead,
};

const recentLineTitle = daysSinceLine === 0
  ? "今日のトークを残してます"
  : `${previousLineDateLabel}のトークをちょっと残してます`;

const reactionPresentation = {
  "🙂": { kind: "smile", label: "にこにこ" },
  "😅": { kind: "sweat", label: "苦笑い" },
  "😳": { kind: "shy", label: "びっくり" },
  "😮": { kind: "surprise", label: "驚き" },
  "😢": { kind: "sad", label: "しょんぼり" },
  "😉": { kind: "wink", label: "ウインク" },
};

const characters = [
  {
    roman: "Asagiri Saya",
    name: "朝霧沙耶",
    body:
      "予定を決めるときは少し慎重。でも、二人に押されると案外ちゃんと楽しむ。写真を見返してから、あとで小さく感想を足す係。",
  },
  {
    roman: "Itsumi Katayo",
    name: "逸見片代",
    body:
      "気づいたことを短く残す係。新しいものや季節の変化を、すぐ決めずに少し眺める。たまに瑠奈の勢いへ巻き込まれる。",
  },
  {
    roman: "Yumemi Runa",
    name: "夢見瑠奈",
    body:
      "面白そうなものを先に見つける係。普通の予定を少しだけ妙な遊びに変える。写真の中ではだいたい一番先に動いている。",
  },
];

const iconClassBySpeaker = {
  沙耶: "avatar-saya",
  片代: "avatar-katayo",
  瑠奈: "avatar-runa",
};

const iconPathBySpeaker = {
  沙耶: assetPath("assets/icon_saya.png"),
  片代: assetPath("assets/icon_katayo.png"),
  瑠奈: assetPath("assets/icon_runa.png"),
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>三人ノート</title>
    <meta
      name="description"
      content="沙耶・片代・瑠奈が、日々の会話やSNSの断片を置いていく場所です。"
    />
    <link rel="stylesheet" href={assetPath("styles.css")} />
  </head>
  <body>
    <header class="site-header" aria-label="サイトヘッダー">
      <a class="brand" href="#top" aria-label="三人ノート トップへ">
        <span class="brand-mark">三</span>
        <span>三人ノート</span>
      </a>
      <nav class="nav" aria-label="メインナビゲーション">
        <a href="#today">今日のこと</a>
        <a href="#line">トーク</a>
        <a href="#characters">書いてる人</a>
        <a href="#sns">近況</a>
        <a href="#stories">置き場</a>
        <a href="#about">この場所</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <img
          class="hero-image"
          src={assetPath("assets/group_sea_05.png")}
          alt="夕暮れの海辺で跳ねる三人のシルエット"
        />
        <div class="hero-overlay">
          <p class="eyebrow">Saya / Katayo / Runa</p>
          <h1 id="hero-title">今日も三人がそこにいる。</h1>
          <p class="hero-copy">
            沙耶・片代・瑠奈が、日々の会話やSNSの断片を置いていく場所です。
            カフェの話、休日の写真、あとで見返したくなった会話を少しずつ残しています。
          </p>
          <div class="hero-actions" aria-label="主要リンク">
            <a class="button primary" href="#today">最新のメモ</a>
            <a class="button" href="#line">今日のトーク</a>
          </div>
        </div>
      </section>

      <section id="today" class="section today-band" aria-labelledby="today-title">
        <div class="section-inner two-column">
          <div>
            <p class="eyebrow">{todayPost.date} / 今日のX</p>
            <h2 id="today-title">{todayPost.title}</h2>
            <p>
              {todayPost.fallback}
            </p>
          </div>
          <article class:list={["post-panel", !todayPost.hasPost && "post-empty"]} aria-label="今日のX">
            <div class="post-meta">
              <span>{todayPost.handle}</span>
              <span>{todayPost.seed}</span>
            </div>
            {
              todayPost.hasPost ? (
                <p>{todayPost.lines.map((line) => <>{line}<br /></>)}</p>
              ) : (
                <p>今日はまだ何も書いてません。</p>
              )
            }
          </article>
        </div>
      </section>

      <section id="line" class="section line-band" aria-labelledby="line-title">
        <div class="section-inner two-column">
          <div>
            <p class="eyebrow">Talk</p>
            <h2 id="line-title">あとで見返した会話</h2>
            <p>
              {lineThread.lead}
            </p>
          </div>
          <article class="phone-frame" aria-label="三人のトーク">
            <header class="phone-header">
              <span class="phone-back">‹</span>
              <div>
                <strong>{lineThread.title}</strong>
                <span>{lineThread.lastUpdatedLabel}</span>
              </div>
              <span class="owner-day">{lineThread.ownerLabel}</span>
            </header>
            <div class="chat-log">
              {lineThread.messages.map((message) => {
                if (message.type === "sticker") {
                  return (
                    <div class="chat-row sticker-row">
                      <span class="line-sticker">{message.body}</span>
                    </div>
                  );
                }
                const mine = message.speaker === lineThread.owner;
                return (
                  <div class:list={["chat-row", mine && "mine"]}>
                    {!mine && (
                      <span
                        class:list={["avatar", iconClassBySpeaker[message.speaker]]}
                        style={`background-image: url('${iconPathBySpeaker[message.speaker]}')`}
                        aria-label={`${message.speaker}のアイコン`}
                      />
                    )}
                    <div class="bubble-group">
                      {!mine && <span class="speaker-name">{message.speaker}</span>}
                      <p class:list={["bubble", mine ? "bubble-mine" : "bubble-other"]}>
                        {message.body}
                        {message.reaction && reactionPresentation[message.reaction] && (
                          <span
                            class:list={[
                              "message-reaction",
                              `reaction-${reactionPresentation[message.reaction].kind}`,
                            ]}
                            role="img"
                            aria-label={reactionPresentation[message.reaction].label}
                          >
                            <span class="reaction-eyes"></span>
                            <span class="reaction-mouth"></span>
                            <span class="reaction-mark"></span>
                          </span>
                        )}
                      </p>
                    </div>
                  </div>
                );
              })}
            </div>
          </article>
        </div>
      </section>

      <section id="characters" class="section" aria-labelledby="characters-title">
        <div class="section-inner">
          <div class="section-heading">
            <p class="eyebrow">Characters</p>
            <h2 id="characters-title">書いてる人たち</h2>
          </div>
          <div class="character-grid">
            {characters.map((character) => (
              <article class="character-card">
                <p class="character-kana">{character.roman}</p>
                <h3>{character.name}</h3>
                <p>{character.body}</p>
              </article>
            ))}
          </div>
          <p class="note-link">
            週に一度くらい、少し長めのメモは
            <a href={externalLinks.note} target="_blank" rel="noopener noreferrer">
              note
              <span>外部</span>
            </a>
            に置いています。
          </p>
        </div>
      </section>

      <section id="sns" class="section muted" aria-labelledby="sns-title">
        <div class="section-inner split-list">
          <div class="section-heading">
            <p class="eyebrow">Recent</p>
            <h2 id="sns-title">最近置いたもの</h2>
            <p>
              短いメモ、トーク、あとで文章にしたいことを日付ごとに置いていきます。
              ちゃんと書く前の、まだ少し温度が残っているものもあります。
            </p>
          </div>
          <div class="link-list">
            <a href="#today">
              <span>{todayPost.date}</span>
              <strong>{todayPost.title}</strong>
            </a>
            <a href="#line">
              <span>最新LINE / {lineThread.lastUpdatedLabel}</span>
              <strong>{recentLineTitle}</strong>
            </a>
          </div>
        </div>
      </section>

      <section id="stories" class="section" aria-labelledby="stories-title">
        <div class="section-inner split-list">
          <div class="section-heading">
            <p class="eyebrow">Short Scenes</p>
            <h2 id="stories-title">あとで読む置き場</h2>
            <p>
              長くなった話や、写真だけでは足りなかった日のことを置く場所です。
              気が向いたときに、少しずつ増やしていきます。
            </p>
          </div>
          {
            stories.length ? (
              <div class="story-list">
                {stories.map((story) => (
                  <article class="story-card">
                    <div class="story-meta">
                      <span>{story.date}</span>
                      <span>{story.place}</span>
                    </div>
                    <h3>{story.title}</h3>
                    <p>{story.summary}</p>
                    <details class="story-body">
                      <summary>読む</summary>
                      <div>
                        {story.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                      </div>
                    </details>
                  </article>
                ))}
              </div>
            ) : (
              <div class="empty-list">
                <p>置き場を準備中</p>
              </div>
            )
          }
        </div>
      </section>

      <section id="about" class="section closing" aria-labelledby="about-title">
        <div class="section-inner narrow">
          <p class="eyebrow">About</p>
          <h2 id="about-title">この場所について</h2>
          <p>
            ここは、三人で出かけたこと、カフェで話したこと、あとから少し笑ったことを置いておく場所です。
            きちんとした日記というより、忘れないための共有ノートに近いです。
          </p>
          <p>
            更新はゆっくりです。何も起きなかった日も、あとで見返すと意外と残っているものがあります。
          </p>
        </div>
      </section>
    </main>
  </body>
</html>
