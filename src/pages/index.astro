---
import { externalLinks } from "../siteConfig";

const dailyModules = import.meta.glob("../data/daily/*.json", { eager: true });
const dailyItems = Object.values(dailyModules)
  .map((module) => module.default)
  .sort((a, b) => a.date.localeCompare(b.date));

const storyModules = import.meta.glob("../data/stories/*.json", { eager: true });
const stories = Object.values(storyModules)
  .map((module) => module.default)
  .filter((story) => story.status !== "draft")
  .sort((a, b) => b.date.localeCompare(a.date));

const assetPath = (path) => path.replace(/^\//, "");
const stylePath = `${assetPath("styles.css")}?v=20260705-1`;
const defaultStoryImage = "assets/story_shopping_back.png";
const storyImagePath = (story) => assetPath(story.image ?? defaultStoryImage);

const latestDaily = dailyItems.at(-1);
const latestLineDaily = [...dailyItems].reverse().find((item) => item.line?.hasLine);
const daysSinceLine = latestDaily && latestLineDaily
  ? Math.max(0, Math.round((Date.parse(latestDaily.date) - Date.parse(latestLineDaily.date)) / 86400000))
  : 0;

const previousLineDateLabel = daysSinceLine === 1 ? "昨日" : `${daysSinceLine}日前`;
const latestLineLabel = daysSinceLine === 0 ? "最終更新 今日" : `最終更新 ${daysSinceLine}日前`;
const latestLineLead = "三人のトークです。";
const latestStory = stories[0];
const storyPath = (story) => `stories/${story.id}/`;

const todayPost = {
  date: latestDaily.date,
  seed: latestDaily.seed.label,
  title: latestDaily.x.hasPost ? latestDaily.noteMemo.titleCandidate : "今日はまだ何も書いてません。",
  owner: latestDaily.eventOwner,
  handle: latestDaily.x.handle ?? `@${latestDaily.eventOwner}`,
  hasPost: latestDaily.x.hasPost,
  lines: latestDaily.x.text ? latestDaily.x.text.split("\n") : [],
  fallback: latestDaily.x.hasPost
    ? ""
    : "でも昨日のトークはちょっと残してます。駅で見るだけだった朝のことは、週末メモに回すかもしれません。",
};

const lineThread = {
  owner: latestLineDaily.eventOwner,
  ownerLabel: `${latestLineDaily.eventOwner}の日`,
  lastUpdatedLabel: latestLineLabel,
  title: latestLineDaily.line.title ?? "三人のトーク",
  messages: latestLineDaily.line.messages,
  lead: latestLineLead,
};

const recentLineTitle = daysSinceLine === 0
  ? "今日のトークを残してます"
  : `${previousLineDateLabel}のトークをちょっと残してます`;

const reactionPresentation = {
  "🙂": { kind: "smile", label: "にこにこ" },
  "😅": { kind: "sweat", label: "苦笑い" },
  "😳": { kind: "shy", label: "びっくり" },
  "😮": { kind: "surprise", label: "驚き" },
  "😢": { kind: "sad", label: "しょんぼり" },
  "😉": { kind: "wink", label: "ウインク" },
};

const stickerPresentation = {
  笑: { kind: "smile", label: "笑" },
  しょんぼり: { kind: "sad", label: "しょんぼり" },
  うんうん: { kind: "nod", label: "うんうん" },
  疑問: { kind: "question", label: "疑問" },
  びっくり: { kind: "surprise", label: "びっくり" },
  ためいき: { kind: "sigh", label: "ためいき" },
  ハート: { kind: "heart", label: "ハート" },
  拍手: { kind: "clap", label: "拍手" },
};

const getStickerName = (message) => {
  const raw = message.sticker ?? message.body ?? "";
  return String(raw).replace(/^【/, "").replace(/】$/, "").replace(/^（/, "").replace(/）$/, "");
};

const getStickerPresentation = (message) => {
  const name = getStickerName(message);
  return stickerPresentation[name] ?? { kind: "plain", label: name || "スタンプ" };
};

const characters = [
  {
    introBy: "瑠奈より",
    name: "朝霧沙耶",
    shortName: "沙耶",
    imageClass: "profile-saya",
    body:
      "沙耶は、ちゃんとしようとして少し背筋が伸びる人。でも安心すると、いちばん柔らかく笑う。褒めるとすぐ照れるから、そこはもう少し慣れてほしい。",
  },
  {
    introBy: "沙耶より",
    name: "逸見片代",
    shortName: "片代",
    imageClass: "profile-katayo",
    body:
      "片代は、気づく前に気づいてくれる人。みんなが楽にいられるように、いつも少しだけ先に動いている。でも自分のことになると急に迷うから、そこは少し可愛い。",
  },
  {
    introBy: "片代より",
    name: "夢見瑠奈",
    shortName: "瑠奈",
    imageClass: "profile-runa",
    body:
      "瑠奈は、面白そうと思ったら先に足が動く人。失敗しても、なぜか最後には笑い話にしてしまう。気づいたら周りまで巻き込まれていて、でも大事なことは雑にしない。",
  },
];

const iconClassBySpeaker = {
  沙耶: "avatar-saya",
  片代: "avatar-katayo",
  瑠奈: "avatar-runa",
};

const iconPathBySpeaker = {
  沙耶: assetPath("assets/icon_saya.png"),
  片代: assetPath("assets/icon_katayo.png"),
  瑠奈: assetPath("assets/icon_runa.png"),
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>三人ノート</title>
    <meta
      name="description"
      content="沙耶・片代・瑠奈が、日々の会話やSNSの断片を置いていく場所です。"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Klee+One:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={stylePath} />
  </head>
  <body>
    <header class="site-header" aria-label="サイトヘッダー">
      <a class="brand" href="#top" aria-label="三人ノート トップへ">
        <span class="brand-mark">三</span>
        <span>三人ノート</span>
      </a>
      <nav class="nav" aria-label="メインナビゲーション">
        <a href="#today">今日のこと</a>
        <a href="#line">トーク</a>
        <a href="#characters">書いてる人</a>
        <a href="#sns">近況</a>
        <a href="#stories">置き場</a>
        <a href="#about">この場所</a>
      </nav>
    </header>

    <main id="top" class="notebook-page">
      <section class="intro-board" aria-labelledby="hero-title">
        <div class="hero-copy-card">
          <p class="eyebrow">三人のトークと、わたしたちのメモ。</p>
          <h1 id="hero-title">あとで見返したくなる、三人のノート。</h1>
          <p>
            カフェで話したこと、帰り道に笑ったこと、あとから少し思い出したこと。
            三人で過ごした日を、少しずつここに残しています。
          </p>
          <div class="hero-actions" aria-label="主要リンク">
            <a class="button primary" href="#line">トークを見る</a>
            <a class="button" href="#stories">置き場へ</a>
          </div>
        </div>
        <figure class="hero-photo taped-photo">
          <img
            src={assetPath("assets/group_sea_05.png")}
            alt="夕暮れの海辺で跳ねる三人のシルエット"
          />
        </figure>
      </section>

      <section class="note-dashboard" aria-label="三人ノートの最新">
        <article id="line" class="paper-card talk-card" aria-labelledby="line-title">
          <div class="section-heading compact">
            <p class="eyebrow">三人のトーク</p>
            <h2 id="line-title">気づいたこと、どうでもいいこと、ぜんぶここに置いていく。</h2>
            <a class="text-link" href="#line-detail">トークをもっと見る</a>
          </div>
          <article id="line-detail" class="phone-frame" aria-label="三人のトーク">
            <header class="phone-header">
              <span class="phone-back">‹</span>
              <div>
                <strong>{lineThread.title}</strong>
                <span>{lineThread.lastUpdatedLabel}</span>
              </div>
              <span class="owner-day">{lineThread.ownerLabel}</span>
            </header>
            <div class="chat-log">
              {lineThread.messages.map((message) => {
                if (message.type === "sticker") {
                  const sticker = getStickerPresentation(message);
                  return (
                    <div class="chat-row sticker-row">
                      <span
                        class:list={["line-sticker", `sticker-${sticker.kind}`]}
                        role="img"
                        aria-label={`${message.speaker ? `${message.speaker}の` : ""}${sticker.label}スタンプ`}
                      >
                        <span class="sticker-face" aria-hidden="true">
                          <span class="sticker-eyes"></span>
                          <span class="sticker-mouth"></span>
                          <span class="sticker-mark"></span>
                        </span>
                        <span class="sticker-label">{sticker.label}</span>
                      </span>
                    </div>
                  );
                }
                const mine = message.speaker === lineThread.owner;
                return (
                  <div class:list={["chat-row", mine && "mine"]}>
                    {!mine && (
                      <span
                        class:list={["avatar", iconClassBySpeaker[message.speaker]]}
                        style={`background-image: url('${iconPathBySpeaker[message.speaker]}')`}
                        aria-label={`${message.speaker}のアイコン`}
                      />
                    )}
                    <div class="bubble-group">
                      {!mine && <span class="speaker-name">{message.speaker}</span>}
                      <p class:list={["bubble", mine ? "bubble-mine" : "bubble-other"]}>
                        {message.body}
                        {message.reaction && reactionPresentation[message.reaction] && (
                          <span
                            class:list={[
                              "message-reaction",
                              `reaction-${reactionPresentation[message.reaction].kind}`,
                            ]}
                            role="img"
                            aria-label={reactionPresentation[message.reaction].label}
                          >
                            <span class="reaction-eyes"></span>
                            <span class="reaction-mouth"></span>
                            <span class="reaction-mark"></span>
                          </span>
                        )}
                      </p>
                    </div>
                  </div>
                );
              })}
            </div>
          </article>
        </article>

        <div class="side-stack">
          <article id="today" class:list={["paper-card", "x-card", !todayPost.hasPost && "post-empty"]} aria-labelledby="today-title">
          <div class="card-title-row">
            <p class="eyebrow">今日のひとこと</p>
            <span class="x-mark">X</span>
          </div>
          <div class="post-author">
            <span class:list={["avatar", iconClassBySpeaker[todayPost.owner]]} style={`background-image: url('${iconPathBySpeaker[todayPost.owner]}')`}></span>
            <div>
              <strong>{todayPost.owner}</strong>
              <span>{todayPost.handle}</span>
            </div>
          </div>
          <h2 id="today-title">{todayPost.title}</h2>
          {
            todayPost.hasPost ? (
              <p class="x-text">{todayPost.lines.map((line) => <>{line}<br /></>)}</p>
            ) : (
              <p class="x-text">今日はまだ何も書いてません。</p>
            )
          }
          <p class="card-foot">{todayPost.date} / {todayPost.seed}</p>
          </article>

          <section id="sns" class="paper-card archive-card" aria-labelledby="sns-title">
            <div class="card-title-row">
              <div>
                <p class="eyebrow">ノートの置き場</p>
                <h2 id="sns-title">最近残したもの</h2>
              </div>
              <span class="clip-mark">⌘</span>
            </div>
            <div class="mini-note-list">
              <a href="#today">
                <span>日々のこと</span>
                <strong>{todayPost.title}</strong>
              </a>
              <a href="#line">
                <span>トーク</span>
                <strong>{recentLineTitle}</strong>
              </a>
              <a href={externalLinks.note} target="_blank" rel="noopener noreferrer">
                <span>note 外部</span>
                <strong>週に一度くらいの長めのメモ</strong>
              </a>
            </div>
          </section>
        </div>

        <article id="stories" class="paper-card story-feature wide-card" aria-labelledby="stories-title">
          <p class="eyebrow">なんでもない日を、少しだけ書き足して</p>
          {
            latestStory ? (
              <>
                <img
                  class="story-thumb"
                  src={storyImagePath(latestStory)}
                  alt={latestStory.imageAlt ?? ""}
                  style={latestStory.imagePosition ? `object-position: ${latestStory.imagePosition}` : undefined}
                />
                <div class="story-meta">
                  <span>{latestStory.date}</span>
                  <span>{latestStory.place}</span>
                </div>
                <h2 id="stories-title">{latestStory.title}</h2>
                <p>三人で過ごした日のことを、少し長めに書いています。</p>
                <div class="story-actions">
                  <a class="story-read-link" href={storyPath(latestStory)}>この日のことを読む</a>
                  <a class="text-link" href="stories/">書き足した日を読む</a>
                </div>
              </>
            ) : (
              <>
                <h2 id="stories-title">置き場を準備中</h2>
                <p>三人で過ごした日のことを、少し長めに書いています。</p>
              </>
            )
          }
        </article>

      </section>

      <section id="characters" class="section character-section" aria-labelledby="characters-title">
        <div class="section-inner">
          <div class="section-heading">
            <p class="eyebrow">書いている三人</p>
            <h2 id="characters-title">書いている三人のこと</h2>
          </div>
          <div class="character-grid">
            {characters.map((character) => (
              <article class="character-card">
                <div class:list={["profile-photo", character.imageClass]} aria-hidden="true"></div>
                <div>
                  <p class="character-kana">{character.introBy}</p>
                  <h3>{character.shortName}</h3>
                  <p>{character.body}</p>
                </div>
              </article>
            ))}
          </div>
          <p class="note-link">
            週に一度くらい、少し長めのメモは
            <a href={externalLinks.note} target="_blank" rel="noopener noreferrer">
              note
              <span>外部</span>
            </a>
            に置いています。
          </p>
        </div>
      </section>

      <section id="about" class="section closing" aria-labelledby="about-title">
        <div class="section-inner narrow">
          <p class="eyebrow">この場所</p>
          <h2 id="about-title">きちんとした日記より、忘れないための共有ノート。</h2>
          <p>
            ここは、三人で出かけたこと、カフェで話したこと、あとから少し笑ったことを置いておく場所です。
            何も起きなかった日も、あとで見返すと意外と残っているものがあります。
          </p>
        </div>
      </section>
    </main>
  </body>
</html>
